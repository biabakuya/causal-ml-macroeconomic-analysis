		Exchange_Rate__t [label="Exchange Rate (t)" fillcolor="#1d4ed8" fixedsize=true fontcolor=white height=1.1600000000000001 width=2.54]
		GDP_Growth__t [label="GDP Growth (t)" fillcolor="#facc15" fixedsize=true fontcolor=black height=0.9199999999999999 width=1.9000000000000001]
